# Application
APP_TITLE="FraudShield AI — Explainability API"
APP_VERSION="1.0.0"
DEBUG=false
LOG_LEVEL=INFO

# Paths
MODEL_DIR=./models
DATA_DIR=./data/processed

# CORS (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# SHAP
SHAP_TOP_N=5
SHAP_BACKGROUND_SIZE=250

# Classification thresholds (0.0 – 1.0)
FRAUD_THRESHOLD=0.70
SUSPICIOUS_THRESHOLD=0.40

# API limits
BATCH_LIMIT=1000
TRANSACTIONS_PAGE_SIZE=50
TRANSACTIONS_CACHE_SIZE=10000

# Model filenames (swap when friend delivers real models — no code change needed)
XGBOOST_MODEL_FILENAME=xgboost_model.pkl
ISOLATION_FOREST_FILENAME=isolation_forest.pkl
SHAP_EXPLAINER_FILENAME=shap_explainer.pkl
SHAP_GLOBAL_CACHE_FILENAME=shap_global_cache.json
SCORED_TRANSACTIONS_FILENAME=scored_transactions.parquet
MODEL_STATS_FILENAME=model_stats.json
