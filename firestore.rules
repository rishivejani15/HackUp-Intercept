rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Shared transactions and alerts (readable by authenticated users)
    match /transactions/{transaction} {
      allow read: if request.auth != null;
      allow write: if false; // Only backend (Admin SDK) should write here
    }
    
    match /alerts/{alert} {
      allow read: if request.auth != null;
      allow write: if false; // Only backend (Admin SDK) should write here
    }
    
    // User profile data (read/write by own user)
    match /profiles/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Default: Deny all
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
